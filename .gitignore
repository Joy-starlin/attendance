# ============================================================
# BUGEMA UNIVERSITY ATTENDANCE SYSTEM — .gitignore
# ============================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# Environment Variables (NEVER commit these!)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Database Files
*.db
*.db-journal
*.sqlite
*.sqlite3
database.sqlite
attendance.db

# Logs
logs/
*.log
log.txt

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Build / Dist directories
dist/
build/
out/
.next/
.nuxt/
.cache/

# Temporary folders
tmp/
temp/
*.tmp
*.temp

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Uploads and generated files
uploads/
public/uploads/
*.pdf
*.csv
*.xlsx

# Testing
.nyc_output/
coverage/

# Misc
*.bak
*.orig
*.rej
