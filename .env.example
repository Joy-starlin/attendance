# ============================================================
# BUGEMA UNIVERSITY ATTENDANCE SYSTEM — Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# PostgreSQL — get this from Railway, Render, or Supabase
DATABASE_URL=postgresql://username:password@host:5432/bugema_attend

# JWT Secret — make this a long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-bugema-site.netlify.app

# ESP32 Master Device Token
# Set this same value in each ESP32's DEVICE_TOKEN constant
ESP32_MASTER_TOKEN=tok_esp32_your_secret_token_here

# Email (optional — for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=attend@bugema.ac.ug
# SMTP_PASS=your_app_password
