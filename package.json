{
  "name": "bugema-attendance-api",
  "version": "2.0.0",
  "description": "Bugema University Biometric Attendance System API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:install": "cd frontend && npm install --include=dev",
    "frontend:build": "cd frontend && npm run build",
    "build": "npm run frontend:install && npm run frontend:build",
    "postinstall": "npm run frontend:install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^2.5.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "biometric",
    "attendance",
    "esp32",
    "university",
    "fingerprint"
  ],
  "author": "Bugema University",
  "license": "MIT"
}
